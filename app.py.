import streamlit as st

st.set_page_config(page_title="LegalCheck KZ", layout="centered")
st.title("⚖️ LegalCheck")
st.write("Анализ договоров по законодательству РК")

text = st.text_area("Вставьте текст договора здесь:", height=300)

if st.button("Проверить договор"):
    if text:
        risks = {
            "одностороннем порядке": "🔴 **Риск по ст. 401 ГК РК:** Одностороннее изменение условий договора.",
            "штраф": "🟡 **Внимание:** Проверьте соразмерность неустойки по ст. 353 ГК РК.",
            "выходные": "🔴 **Трудовой риск:** Проверьте оплату по ст. 109 ТК РК."
        }
        found = False
        for key, value in risks.items():
            if key in text.lower():
                st.warning(value)
                found = True
        if not found:
            st.success("Критических рисков не обнаружено.")
